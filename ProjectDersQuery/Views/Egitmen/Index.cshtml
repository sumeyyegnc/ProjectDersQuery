@{
    ViewBag.Title = "Eğitmen Listesi";
}

<h2>Eğitmen Listesi</h2>

<button type="button" class="btn btn-primary mb-3" id="btnYeniEkle">
    <i class="fa fa-plus"></i> Yeni Eğitmen Ekle
</button>

<table class="table table-bordered table-striped" id="tblEgitmen">
    <thead>
        <tr>
            <th>Eğitmen ID</th>
            <th>Eğitmen Adı</th>
            <th>Branş</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        <!-- JS ile doldurulacak -->
    </tbody>
</table>

<!-- Ekle / Düzenle Modal -->
<div class="modal fade" id="egitmenModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="egitmenModalBaslik">Yeni Eğitmen</h5>
                <button type="button" class="close" data-dismiss="modal" data-bs-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="frmEgitmen">
                    <input type="hidden" id="txtEgitmenId" value="0" />

                    <div class="form-group">
                        <label>Eğitmen Adı</label>
                        <input type="text" class="form-control" id="txtEgitmenAdi" />
                    </div>

                    <div class="form-group">
                        <label>Branş</label>
                        <input type="text" class="form-control" id="txtBrans" />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal" data-bs-dismiss="modal">Kapat</button>
                <button type="button" class="btn btn-success" id="btnKaydet">Kaydet</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/egitmen.js"></script>
}
