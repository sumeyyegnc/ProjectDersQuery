@{
    ViewData["Title"] = "Kurslar";
}

<!-- HERO -->
<header class="bg-primary text-white text-center py-5">
    <div class="container">
        <h1>Kurslarımıza Hoş Geldiniz</h1>
        <p>En iyi online ve yüz yüze kursları keşfet</p>
        <a href="#courses" class="btn btn-light btn-lg mt-3">Kursları Gör</a>
    </div>
</header>

<!-- COURSES -->
<section id="courses" class="py-5">
    <div class="container">

        <div class="text-center mb-5">
            <h2>Popüler Kurslar</h2>
            <p class="text-muted">Güncel ve en çok tercih edilen kurslar</p>
        </div>

        <div class="row g-4">

            <!-- Kurs 1 -->
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-code-slash fs-1 text-primary"></i>
                        <h5 class="mt-3">C# Programlama</h5>
                        <p>Başlangıçtan ileri seviyeye C# öğrenin.</p>
                        <a href="/Ogrenci/Index" class="btn btn-primary">Detay</a>
                    </div>
                </div>
            </div>

            <!-- Kurs 2 -->
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-globe fs-1 text-primary"></i>
                        <h5 class="mt-3">Web Geliştirme</h5>
                        <p>HTML, CSS, JavaScript ve ASP.NET Core.</p>
                        <a href="/Ogrenci/Index" class="btn btn-primary">Detay</a>
                    </div>
                </div>
            </div>

            <!-- Kurs 3 -->
            <div class="col-md-4">
                <div class="card shadow-sm h-100">
                    <div class="card-body text-center">
                        <i class="bi bi-phone fs-1 text-primary"></i>
                        <h5 class="mt-3">Mobil Uygulama</h5>
                        <p>Android ve .NET MAUI ile mobil geliştirme.</p>
                        <a href="/Ogrenci/Index" class="btn btn-primary">Detay</a>
                    </div>
                </div>
            </div>

        </div>
    </div>
</section>

<!-- ABOUT -->
<section class="bg-light py-5">
    <div class="container text-center">
        <h2>Neden Biz?</h2>
        <p class="text-muted">
            Uzman eğitmenler, güncel içerikler ve proje bazlı eğitim.
        </p>
    </div>
</section>