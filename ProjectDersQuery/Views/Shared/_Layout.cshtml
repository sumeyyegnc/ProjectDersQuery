<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ProjectDersQuery</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Bootstrap Icons -->
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.5.0/font/bootstrap-icons.css" rel="stylesheet" />

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css?family=Merriweather+Sans:400,700" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css?family=Merriweather:400,300,300italic,400italic,700,700italic" rel="stylesheet" />

    <!-- SimpleLightbox -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/SimpleLightbox/2.1.0/simpleLightbox.min.css" rel="stylesheet" />

    <!-- Theme CSS -->
    <link href="~/css/styles.css" rel="stylesheet" />
    <link href="~/css/site.css" rel="stylesheet" />

</head>

<body id="page-top">

    <!-- NAVBAR (Bootstrap + senin proje yapın) -->
    <nav class="navbar navbar-expand-sm navbar-light bg-white border-bottom box-shadow mb-3">
        <div class="container-fluid">
            <a class="navbar-brand" asp-controller="Home" asp-action="Index">ProjectDersQuery</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target=".navbar-collapse">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="navbar-collapse collapse d-sm-inline-flex justify-content-between">
                <ul class="navbar-nav flex-grow-1">
                    <li class="nav-item">
                    </li>                  
                </ul>
            </div>
        </div>
    </nav>

    <!-- 🔥 BOOTSTRAP THEME NAVBAR (Creative) -->
    <nav class="navbar navbar-expand-lg navbar-light fixed-top py-3" id="mainNav">
        <div class="container px-4 px-lg-5">
            <a class="navbar-brand" href="#page-top">Kurs Manager</a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarResponsive">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="navbarResponsive">
                <ul class="navbar-nav ms-auto my-2 my-lg-0">
                    <li class="nav-item"><a class="nav-link" href="/Home/Index">Ana Sayfa</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Kurs/Index">Kurslar</a></li>
                    <li class="nav-item"><a class="nav-link" href="/Egitmen/Index">Egitmen Kadromuz</a></li>
                   
                </ul>
            </div>
        </div>
    </nav>

    <!-- MAIN CONTENT -->
    <main role="main">
        @RenderBody()
    </main>



    <!-- CONTACT -->
    <section class="page-section" id="contact">
        <div class="container px-4 px-lg-5">

            <div class="row justify-content-center">
                <div class="col-lg-8 text-center">        
                    <hr class="divider" />
                    <p class="text-muted mb-5">Kurslara Hemen Göz At</p>
                </div>
            </div>

          

        </div>
    </section>

    <!-- FOOTER -->
    <footer class="border-top footer text-muted bg-light py-5">
        <div class="container text-center">
            &copy; 2026 - ProjectDersQuery
        </div>
    </footer>

    <!-- SCRIPTS -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    <script src="https://cdnjs.cloudflare.com/ajax/libs/SimpleLightbox/2.1.0/simpleLightbox.min.js"></script>
    <script src="https://cdn.startbootstrap.com/sb-forms-latest.js"></script>

    <script src="~/js/site.js"></script>
    <script src="~/js/scripts.js"></script>

    @RenderSection("Scripts", required: false)

</body>
</html>