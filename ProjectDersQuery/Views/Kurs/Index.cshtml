@{
    ViewBag.Title = "Kurs Listesi";
}

<h2>Kurs Listesi</h2>

<button type="button" class="btn btn-primary mb-3" id="btnYeniEkle">
    <i class="fa fa-plus"></i> Yeni Kurs Ekle
</button>

<table class="table table-bordered table-striped" id="tblKurs">
    <thead>
        <tr>
            <th>Kurs ID</th>
            <th>Kurs Adı</th>
            <th>Ücret</th>
            <th>İşlemler</th>
        </tr>
    </thead>
    <tbody>
        <!-- JS ile doldurulacak -->
    </tbody>
</table>

<!-- Ekle / Düzenle Modal -->
<div class="modal fade" id="kursModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="kursModalBaslik">Yeni Kurs</h5>
                <button type="button" class="close" data-dismiss="modal" data-bs-dismiss="modal">&times;</button>
            </div>
            <div class="modal-body">
                <form id="frmKurs">
                    <input type="hidden" id="txtKursId" value="0" />

                    <div class="form-group">
                        <label>Kurs Adı</label>
                        <input type="text" class="form-control" id="txtKursAdi" />
                    </div>

                    <div class="form-group">
                        <label>Ücret</label>
                        <input type="number" class="form-control" id="txtUcret" />
                    </div>
                </form>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-dismiss="modal" data-bs-dismiss="modal">Kapat</button>
                <button type="button" class="btn btn-success" id="btnKaydet">Kaydet</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/kurs.js"></script>
}
